# Deep network for text classification
# Purpose of this code: Go over some operations on an easier example
# such as the layer embedding function (basically you can provide the shape of your input)
# padding and string tokenization
# In addition the example goes over some pretrained sentiment libraries
install.packages("keras")
library(keras)
library(syuzhet)
library(keras)
