# Represent the Sentiment for each tweet
s <- get_nrc_sentiment(tweets)
s
get_nrc_sentiment('anime')
get_nrc_sentiment('death')
# These are different sentiment lexicons, containing different pretrained sentiment opinions
get_sentiment(tweets, method="syuzhet")
get_sentiment(tweets, method="bing")
get_sentiment(tweets, method="afinn")
model <- keras_model_sequential()
model <- keras_model_sequential()
model %>% layer_embedding( input_dim = 10,
output_dim = 8,
input_length = 5)
model$get_weights()
